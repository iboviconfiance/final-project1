# Configuration de la base de données
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=votre_db_name
DB_USER=votre_db_user
DB_PASS=votre_db_pass

# Configuration de l'application
PORT=3000
NODE_ENV=development

# Sécurité (JWT) — OBLIGATOIRE
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS
CORS_ORIGIN=*

# ============================================================
# EMAIL (SMTP) — pour les notifications
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ============================================================
# PAIEMENT — Clés API des providers
# ============================================================
MTN_CONGO_API_KEY=
MTN_CONGO_WEBHOOK_SECRET=
AIRTEL_CONGO_API_KEY=
AIRTEL_CONGO_WEBHOOK_SECRET=
AGGREGATOR_API_KEY=
AGGREGATOR_WEBHOOK_SECRET=

# URL de l'application (pour les QR codes des reçus)
APP_URL=https://app.example.com

# ============================================================
# MONITORING — MonitorMe (Zero-Trust)
# ============================================================
# Clé de monitoring (32+ caractères aléatoires)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONITOR_API_KEY=

# ============================================================
# LICENCE (Option B — On-Premise uniquement)
# ============================================================
# Ne pas définir pour le mode Plateforme (Option A)
# LICENSE_KEY=
# LICENSE_SECRET=

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info

# ============================================================
# CHIFFREMENT — Données sensibles (numéro MoMo, etc.)
# ============================================================
# Clé de chiffrement AES-256-GCM (min 16 caractères)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ IMPORTANT : Si cette clé est perdue, les données chiffrées sont IRRÉCUPÉRABLES
ENCRYPTION_KEY=

# ============================================================
# WEB PUSH — Notifications Push (VAPID)
# ============================================================
# Générer les clés VAPID avec :
# node -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY=' + k.publicKey); console.log('VAPID_PRIVATE_KEY=' + k.privateKey);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com

# ============================================================
# VERSION DE L'APPLICATION
# ============================================================
APP_VERSION=1.0.0
